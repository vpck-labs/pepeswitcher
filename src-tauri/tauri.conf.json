{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PepeSwitcher",
  "version": "0.1.0",
  "identifier": "com.wintools.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PepeSwitcher",
        "width": 360,
        "height": 720,
        "resizable": false,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/multimonitortool",
      "binaries/soundvolumeview"
    ],
    "resources": {
      "resources/nirsoft/multimonitortool/*": "resources/nirsoft/multimonitortool/",
      "resources/nirsoft/soundvolumeview/*": "resources/nirsoft/soundvolumeview/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
